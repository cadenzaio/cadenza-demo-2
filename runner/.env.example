# Copy this file to .env for local Docker Compose runs.

# Runtime basics
NODE_ENV=production
IS_DOCKER=true
CADENZA_SERVER_URL=scheduled-runner
HTTP_PORT=3002
SECURITY_PROFILE=low
NETWORK_MODE=dev

# Internal CadenzaDB transport.
CADENZA_DB_ADDRESS=cadenza-db-service
CADENZA_DB_PORT=8080

# Demo traffic controls.
# Use TRAFFIC_MODE=high for a heavier load profile.
TRAFFIC_MODE=low
DEVICE_COUNT=50
