# Copy this file to .env for local Docker Compose runs.

# Runtime basics
NODE_ENV=production
IS_DOCKER=true
CADENZA_SERVER_URL=predictor
HTTP_PORT=3005
SECURITY_PROFILE=low
NETWORK_MODE=dev

# Internal CadenzaDB transport.
CADENZA_DB_ADDRESS=cadenza-db-service
CADENZA_DB_PORT=8080

# Internal IoT DB service transport.
IOT_DB_SERVICE_ADDRESS=iot-db-service
IOT_DB_SERVICE_PORT=3001

# Optional weather enrichment key. Leave blank to use neutral weather context.
# WEATHER_API_KEY=your_openweathermap_key
