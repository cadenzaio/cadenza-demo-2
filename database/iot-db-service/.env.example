# Copy this file to .env for local Docker Compose runs.

# Runtime basics
NODE_ENV=production
IS_DOCKER=true
CADENZA_SERVER_URL=iot-db-service
HTTP_PORT=3001
SECURITY_PROFILE=low
NETWORK_MODE=dev

# Internal CadenzaDB transport.
CADENZA_DB_ADDRESS=cadenza-db-service
CADENZA_DB_PORT=8080

# Postgres connection used by the IoT DB service.
DATABASE_ADDRESS=postgresql://iot_user:iot_pass@iot-db:5432/postgres?sslmode=disable
DATABASE_PORT=5432
DATABASE_USER=iot_user
DATABASE_PASSWORD=iot_pass
DATABASE_NAME=iot_db_service
