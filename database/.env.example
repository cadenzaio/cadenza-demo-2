# Copy this file to .env for local Docker Compose runs.

# Runtime basics
NODE_ENV=production
IS_DOCKER=true
CADENZA_SERVER_URL=cadenza-db-service
HTTP_PORT=8080
SECURITY_PROFILE=low
NETWORK_MODE=dev

# Keep high-volume debug flags disabled by default.
CADENZA_DB_TASK_DEBUG=false
CADENZA_DB_SYNC_DEBUG=false
CADENZA_DB_RUNTIME_DIAGNOSTICS=false

# Postgres connection used by the CadenzaDB service.
DATABASE_POOL_SIZE=10
DATABASE_USER=iot_user
DATABASE_PASSWORD=iot_pass
DATABASE_ADDRESS=postgresql://iot_user:iot_pass@iot-db:5432/postgres?sslmode=disable
DATABASE_PORT=5432
DATABASE_NAME=cadenza_db
